{
  "name": "mergerisk-action",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action that posts pull request merge-risk reports.",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "tsc --noEmit && ncc build src/main.ts -o dist --source-map",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "minimatch": "^10.0.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vercel/ncc": "^0.38.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
